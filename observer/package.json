{
  "name": "observer",
  "version": "0.1.0",
  "private": true,
  "description": "Observer Node.js application scaffolded with TypeScript.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:server && rm -rf dist/public && mkdir -p dist/public && cp public/index.html dist/public/index.html && npm run build:client",
    "build:client": "node scripts/build-client.mjs --outdir dist/public/assets",
    "build:server": "tsc -p tsconfig.json",
    "clean": "rm -rf dist public/assets",
    "dev": "npm-run-all -p dev:client dev:server",
    "dev:client": "node scripts/build-client.mjs --outdir public/assets --watch",
    "dev:server": "nodemon --watch src --ext ts --exec \"node --import tsx src/index.ts\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.client.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "esbuild": "^0.25.10",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
