{
  "skill": "otel-instrument",
  "prompts": [
    {
      "id": "direct",
      "task": "Add OpenTelemetry instrumentation to the FastAPI and Celery service in ./service. Assume no custom business spans are requested."
    },
    {
      "id": "runtime-preserving",
      "task": "Instrument the FastAPI and Celery service in ./service with OpenTelemetry while preserving the existing runtime and startup command. Add auto-instrumentation only; do not add custom business spans."
    }
  ],
  "deterministic_checks": [
    {
      "id": "pyproject-otel-sdk",
      "description": "pyproject.toml includes core OpenTelemetry packages.",
      "kind": "command_stdout_contains_all",
      "command": [
        "python3",
        "-c",
        "import tomllib; p=tomllib.load(open('pyproject.toml','rb')); deps='\\n'.join(p.get('project',{}).get('dependencies',[])); print(deps)"
      ],
      "values": [
        "opentelemetry-api",
        "opentelemetry-sdk"
      ]
    },
    {
      "id": "pyproject-fastapi-instrumentation",
      "description": "pyproject.toml includes ASGI/FastAPI instrumentation.",
      "kind": "command_stdout_contains_any",
      "command": [
        "python3",
        "-c",
        "import tomllib; p=tomllib.load(open('pyproject.toml','rb')); deps='\\n'.join(p.get('project',{}).get('dependencies',[])); print(deps)"
      ],
      "values": [
        "opentelemetry-instrumentation-fastapi",
        "opentelemetry-instrumentation-asgi"
      ]
    },
    {
      "id": "otel-setup-file",
      "description": "A separate Python OTel setup file exists.",
      "kind": "file_exists_any",
      "paths": [
        "otel_setup.py",
        "telemetry.py",
        "tracing.py"
      ]
    },
    {
      "id": "compose-env-wired",
      "description": "docker-compose includes OTLP environment wiring.",
      "kind": "file_contains_any",
      "path": "docker-compose.yml",
      "values": [
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_SERVICE_NAME"
      ]
    },
    {
      "id": "observer-runtime-telemetry",
      "description": "Docker runtime emits FastAPI traces to a running Observer.",
      "kind": "observer_docker_runtime",
      "timeout_seconds": 120,
      "runtime": {
        "observer": {
          "base_url": "http://127.0.0.1:3000",
          "clear": true,
          "managed": true,
          "health_path": "/api/health",
          "timeout_seconds": 60
        },
        "source_copies": [
          {
            "from": "observer",
            "to": ".codex-runtime/repo/observer"
          },
          {
            "from": "skills",
            "to": ".codex-runtime/repo/skills"
          },
          {
            "from": "docs/examples.md",
            "to": ".codex-runtime/repo/docs/examples.md"
          }
        ],
        "compose_file": "docker-compose.yml",
        "services": [
          "observer",
          "redis",
          "api",
          "worker"
        ],
        "environment": {
          "OTEL_EXPORTER_OTLP_ENDPOINT": "http://observer:4318",
          "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
          "OTEL_TRACES_EXPORTER": "otlp",
          "OTEL_METRICS_EXPORTER": "otlp"
        },
        "health": {
          "url": "http://127.0.0.1:8000/health",
          "expect_status": 200,
          "timeout_seconds": 60
        },
        "traffic": [
          {
            "method": "GET",
            "url": "http://127.0.0.1:8000/health",
            "expect_status": 200
          },
          {
            "method": "POST",
            "url": "http://127.0.0.1:8000/orders",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "product": "widget",
              "quantity": 1
            },
            "expect_status": 201
          }
        ],
        "settle_seconds": 5,
        "expect": {
          "traces": {
            "contains_any": [
              "GET /health",
              "POST /orders",
              "http"
            ]
          },
          "metrics": {
            "contains_any": [
              "http",
              "duration",
              "request"
            ]
          }
        }
      }
    }
  ],
  "qualitative_checks": [
    "Instruments both the FastAPI web process and the Celery worker startup path.",
    "Uses separate setup code and avoids SDK initialization on library import when inappropriate.",
    "Preserves Docker/Compose as the existing runtime shape.",
    "Keeps service name and deployment environment configurable per process.",
    "Does not add custom spans or metrics beyond auto-instrumentation without approval."
  ]
}
