{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["skill", "prompts"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "skill": { "type": "string" },
    "language": { "type": "string" },
    "service": { "type": "string" },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "task"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "task": { "type": "string" }
        }
      }
    },
    "deterministic_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "kind"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "final_contains_all",
              "final_contains_any",
              "file_exists",
              "file_exists_any",
              "no_file_exists",
              "file_contains_all",
              "file_contains_any",
              "trace_command_contains",
              "command_succeeds",
              "command_stdout_contains_all",
              "command_stdout_contains_any",
              "command_stdout_contains_none",
              "observer_docker_runtime"
            ]
          },
          "path": { "type": "string" },
          "paths": { "type": "array", "items": { "type": "string" } },
          "values": { "type": "array", "items": { "type": "string" } },
          "command": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "cwd": { "type": "string" },
          "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 300, "default": 30 },
          "runtime": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "observer": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "base_url": { "type": "string" },
                  "clear": { "type": "boolean" },
                  "clear_path": { "type": "string" },
                  "managed": { "type": "boolean" },
                  "health_path": { "type": "string" },
                  "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 300 },
                  "expect_status": { "type": "integer", "minimum": 100, "maximum": 599 }
                }
              },
              "source_copies": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["from", "to"],
                  "additionalProperties": false,
                  "properties": {
                    "from": { "type": "string" },
                    "to": { "type": "string" }
                  }
                }
              },
              "compose_file": { "type": "string" },
              "services": { "type": "array", "items": { "type": "string" } },
              "containers": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
              "environment": { "type": "object", "additionalProperties": { "type": ["string", "number", "boolean"] } },
              "health": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "object", "additionalProperties": true }
                ]
              },
              "traffic": {
                "type": "array",
                "items": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "object", "additionalProperties": true }
                  ]
                }
              },
              "settle_seconds": { "type": "number", "minimum": 0 },
              "expect": { "type": "object", "additionalProperties": true }
            }
          },
          "applies_to": { "type": "string", "enum": ["both", "with_skill", "baseline"], "default": "with_skill" }
        }
      }
    },
    "qualitative_checks": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
