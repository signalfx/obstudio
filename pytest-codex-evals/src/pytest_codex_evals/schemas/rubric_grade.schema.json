{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["overall_pass", "score", "checks"],
  "additionalProperties": false,
  "properties": {
    "overall_pass": { "type": "boolean" },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Percentage-style quality score from 0 to 100, not a count of passed checks."
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "pass", "notes", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "pass": { "type": "boolean" },
          "notes": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    }
  }
}
