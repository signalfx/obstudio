{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime.schema.json",
  "type": "object",
  "required": ["skill", "prompts", "checks"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "skill": { "type": "string" },
    "language": { "type": "string" },
    "service": { "type": "string" },
    "prompts": { "$ref": "common.schema.json#/$defs/prompts" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common.schema.json#/$defs/runtimeCheck" }
    }
  }
}
