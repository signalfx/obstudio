{
  "skill": "otel-instrument",
  "prompts": [
    {
      "id": "runtime-preserving",
      "task": "Instrument the FastAPI and Celery service in ./service with OpenTelemetry while preserving the existing Docker Compose runtime. Add auto-instrumentation only."
    }
  ],
  "deterministic_checks": [
    {
      "id": "observer-runtime-telemetry",
      "description": "Docker runtime emits FastAPI traces to a running Observer.",
      "kind": "observer_docker_runtime",
      "timeout_seconds": 120,
      "runtime": {
        "observer": {
          "base_url": "http://127.0.0.1:3000",
          "clear": true,
          "managed": true,
          "health_path": "/api/health",
          "timeout_seconds": 60
        },
        "source_copies": [
          {
            "from": "observer",
            "to": ".codex-runtime/repo/observer"
          },
          {
            "from": "skills",
            "to": ".codex-runtime/repo/skills"
          },
          {
            "from": "docs/examples.md",
            "to": ".codex-runtime/repo/docs/examples.md"
          }
        ],
        "prebuild": [
          {
            "command": [
              "go",
              "run",
              "./cmd/stage-skills"
            ],
            "cwd": ".codex-runtime/repo/observer",
            "timeout_seconds": 120
          },
          {
            "command": [
              "go",
              "build",
              "-trimpath",
              "-o",
              "bin/obstudio",
              "./cmd/obstudio"
            ],
            "cwd": ".codex-runtime/repo/observer",
            "timeout_seconds": 300,
            "env": {
              "CGO_ENABLED": "0",
              "GOOS": "linux"
            }
          }
        ],
        "compose_file": "docker-compose.yml",
        "services": [
          "observer",
          "redis",
          "api",
          "worker"
        ],
        "environment": {
          "OTEL_EXPORTER_OTLP_ENDPOINT": "http://observer:4318",
          "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
          "OTEL_TRACES_EXPORTER": "otlp",
          "OTEL_METRICS_EXPORTER": "otlp"
        },
        "health": {
          "url": "http://127.0.0.1:8000/health",
          "expect_status": 200,
          "timeout_seconds": 60
        },
        "traffic": [
          {
            "method": "GET",
            "url": "http://127.0.0.1:8000/health",
            "expect_status": 200
          },
          {
            "method": "POST",
            "url": "http://127.0.0.1:8000/orders",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "product": "widget",
              "quantity": 1
            },
            "expect_status": 201
          }
        ],
        "settle_seconds": 5,
        "expect": {
          "traces": {
            "contains_any": [
              "GET /health",
              "POST /orders",
              "http"
            ]
          },
          "metrics": {
            "contains_any": [
              "http",
              "duration",
              "request"
            ]
          }
        }
      }
    }
  ]
}
